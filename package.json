{
  "name": "babylon-unity-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "electron:dev": "node scripts/dev-electron.mjs",
    "electron:build": "tsc -p tsconfig.electron.json",
    "build": "tsc -b && vite build && npm run electron:build",
    "preview": "vite preview --host 0.0.0.0",
    "demo:stacker-ddj2-plc": "node scripts/stacker-ddj2-plc-message.mjs",
    "demo:stacker-ddj2-plc:dry-run": "node scripts/stacker-ddj2-plc-message.mjs --dry-run",
    "demo:stacker-scene": "node scripts/stacker-scene-mqtt-sequence.mjs",
    "demo:stacker-scene:dry-run": "node scripts/stacker-scene-mqtt-sequence.mjs --dry-run",
    "demo:logistics-transformer": "node scripts/logistics-mqtt-transformer.mjs",
    "demo:logistics-transformer:dry-run": "node scripts/logistics-mqtt-transformer.mjs --dry-run",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@babylonjs/core": "^9.0.0",
    "@babylonjs/inspector": "^9.0.0",
    "@babylonjs/loaders": "^9.0.0",
    "earcut": "^3.0.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.local.babylon3deditor",
    "productName": "zdzn 3D Editor",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Babylon 3D Editor"
    }
  },
  "description": "基于 Babylon.js 技术栈实现的桌面 3D 场景编辑器原型，目标是提供接近 Unity Scene View 的基础编辑体验：层级树、中央 3D 视口、属性面板、资产浏览器、拖拽创建、拖拽导入、Gizmo 变换和场景保存。当前工程已接入 Electron，可生成 Windows 安装程序。",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wy32428011/3d-editor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wy32428011/3d-editor/issues"
  },
  "homepage": "https://github.com/wy32428011/3d-editor#readme"
}
